# server/.env — secrets and per-deployment settings ONLY.
#
# Static portal URLs (login pages, portal endpoints) are NOT here: they are the
# same for every deployment, so they live as defaults in app/config.py and are
# the single source of truth. Put only secrets and things that legitimately
# change per environment below.

# -- Portal credentials ------------------------------------------------------
MFMP_EMAIL=your_email_here
MFMP_PASSWORD=your_password_here

RIDEMETRO_EMAIL=your_email_here
RIDEMETRO_PASSWORD=your_password_here

BIDNET_USERNAME=your_email_here
BIDNET_PASSWORD=your_password_here

NORTHDAKOTA_USERNAME=your_username_here
NORTHDAKOTA_PASSWORD=your_password_here
# Manual-login mode: force a visible browser and wait for a human to solve the
# B2C reCAPTCHA. Requires a desktop/display where someone is present.
NORTHDAKOTA_MANUAL_LOGIN=true
NORTHDAKOTA_MANUAL_LOGIN_TIMEOUT=300

SEPTA_USERNAME=your_username_here
SEPTA_PASSWORD=your_password_here

Cal_ePROCURE_USERNAME=your_username_here
Cal_ePROCURE_PASSWORD=your_password_here

# Unison Marketplace credentials (SAM.gov and NAICS need no credentials;
# Wisconsin is a public portal with no login).
UNISON_EMAIL=your_email@example.com
UNISON_PASSWORD=your_password

# -- Post-scrape email / S3 notifications ------------------------------------
# On a successful run the archive ZIP (cumulative Excel + documents) is emailed
# via AWS SES, with the download link in the body and an optional S3 upload.
# Leave RECIPIENT_EMAILS blank to disable notifications entirely.
RECIPIENT_EMAILS=email1@example.com,email2@example.com
AWS_S3_BUCKET_NAME=your_s3_bucket_name
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_SES_FROM_EMAIL=no-reply@yourdomain.com
AWS_SES_USERNAME=your_ses_smtp_username
AWS_SES_PASSWORD=your_ses_smtp_password

# Base URL recipients can reach this server at — used to build the download
# link in the notification email. This is deployment-specific (localhost in dev,
# your public domain/tunnel in production), which is why it belongs here.
PUBLIC_BASE_URL=http://localhost:8000

# -- Storage & runtime (optional — sensible defaults in app/config.py) --------
# WORK_DIR   scratch workspace for in-flight runs (default: system temp dir)
# ARCHIVE_DIR where finished-run ZIPs are stored (default: ../data/archives)
# WORK_DIR=
# ARCHIVE_DIR=../data/archives
HEADLESS=true

# -- Database ----------------------------------------------------------------
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@localhost:5432/scraping-hub
